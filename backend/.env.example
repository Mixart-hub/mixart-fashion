# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://mixart_user:strongpass123@db:5432/mixart_db

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook
TWA_URL=https://yourdomain.com/twa

# ── Google OAuth ─────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized JS origins: https://yourdomain.com
# Authorized redirect URIs: https://yourdomain.com/admin
GOOGLE_CLIENT_ID=

# ── Payment: Click ───────────────────────────────
CLICK_MERCHANT_ID=12345
CLICK_SERVICE_ID=12345
CLICK_SECRET_KEY=your-click-secret

# ── Payment: Payme ───────────────────────────────
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret
PAYME_TEST_MODE=True

# ── App ──────────────────────────────────────────
APP_NAME=Mixart Fashion
DEBUG=False
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]
MEDIA_DIR=media

# ── SMS — Eskiz.uz ─────────────────────────────────
# Eskiz.uz da ro'yxatdan o'ting: notify.eskiz.uz
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_FROM=4546

# ── Email — SMTP ────────────────────────────────────
# Gmail uchun: App Password yarating (2FA kerak)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Mixart Fashion

# ── Gemini AI ───────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
